<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.view.admin.AddBicycleController"
  styleClass="stack-pane-root">

  <VBox spacing="10" alignment="CENTER" styleClass="users-page" prefWidth="400">

    <VBox spacing="4" alignment="CENTER_LEFT">
      <TextField fx:id="modelField" prefWidth="250" styleClass="text-field-style"/>
      <Label fx:id="modelErrorLabel" styleClass="label-error" wrapText="true"/>
    </VBox>

    <VBox spacing="4" alignment="CENTER_LEFT">
      <TextField fx:id="priceField" prefWidth="250" styleClass="text-field-style"/>
      <Label fx:id="priceErrorLabel" styleClass="label-error" wrapText="true"/>
    </VBox>

    <VBox spacing="4" alignment="CENTER_LEFT">
      <TextField fx:id="latitudeField" prefWidth="250" styleClass="text-field-style"/>
      <Label fx:id="latitudeErrorLabel" styleClass="label-error" wrapText="true"/>
    </VBox>

    <VBox spacing="4" alignment="CENTER_LEFT">
      <TextField fx:id="longitudeField" prefWidth="250" styleClass="text-field-style"/>
      <Label fx:id="longitudeErrorLabel" styleClass="label-error" wrapText="true"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER">
      <Button fx:id="saveButton" onAction="#onSave" styleClass="button-primary"/>
      <Button fx:id="cancelButton" onAction="#onCancel" styleClass="button-secondary"/>
    </HBox>

  </VBox>
</StackPane>