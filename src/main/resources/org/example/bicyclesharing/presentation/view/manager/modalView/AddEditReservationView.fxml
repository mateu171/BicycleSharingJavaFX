<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/25"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.view.manager.modalController.AddEditReservationController"
  styleClass="modal-root">

  <VBox prefWidth="500"
    maxWidth="500"
    styleClass="modal-card">

    <HBox alignment="CENTER_LEFT"
      styleClass="modal-header">
      <Label fx:id="titleLabel"
        styleClass="modal-title"/>
      <Pane HBox.hgrow="ALWAYS"/>
    </HBox>

    <VBox spacing="6"
      styleClass="modal-body">

      <VBox spacing="2">
        <Label fx:id="customerLabel" styleClass="form-label"/>
        <ComboBox fx:id="customerComboBox" styleClass="settings-combo"/>
        <Label fx:id="customerErrorLabel" styleClass="label-error" wrapText="true"/>
      </VBox>

      <VBox spacing="2">
        <Label fx:id="bicycleLabel" styleClass="form-label"/>
        <ComboBox fx:id="bicycleComboBox" styleClass="settings-combo"/>
        <Label fx:id="bicycleErrorLabel" styleClass="label-error" wrapText="true"/>
      </VBox>

      <VBox spacing="2">
        <Label fx:id="startTimeLabel" styleClass="form-label"/>
        <TextField fx:id="startTimeField" styleClass="modal-text-field"/>
        <Label fx:id="startTimeErrorLabel" styleClass="label-error" wrapText="true"/>
      </VBox>

      <VBox spacing="2">
        <Label fx:id="endTimeLabel" styleClass="form-label"/>
        <TextField fx:id="endTimeField" styleClass="modal-text-field"/>
        <Label fx:id="endTimeErrorLabel" styleClass="label-error" wrapText="true"/>
      </VBox>

      <VBox spacing="2">
        <Label fx:id="documentTypeLabel" styleClass="form-label"/>
        <ComboBox fx:id="documentTypeComboBox" styleClass="settings-combo"/>
        <Label fx:id="documentTypeErrorLabel" styleClass="label-error" wrapText="true"/>
      </VBox>

      <VBox spacing="2">
        <Label fx:id="documentNumberLabel" styleClass="form-label"/>
        <TextField fx:id="documentNumberField" styleClass="modal-text-field"/>
        <Label fx:id="documentNumberErrorLabel" styleClass="label-error" wrapText="true"/>
      </VBox>

      <VBox spacing="2">
        <Label fx:id="depositAmountLabel" styleClass="form-label"/>
        <TextField fx:id="depositAmountField" styleClass="modal-text-field"/>
        <Label fx:id="depositAmountErrorLabel" styleClass="label-error" wrapText="true"/>
      </VBox>

    </VBox>

    <HBox spacing="2"
      alignment="CENTER_RIGHT"
      styleClass="modal-footer">

      <Button fx:id="cancelButton"
        onAction="#onClose"
        styleClass="button-secondary-outline"/>

      <Button fx:id="saveButton"
        onAction="#onSave"
        styleClass="button-primary"/>
    </HBox>
  </VBox>

  <padding>
    <Insets top="5" right="20" bottom="10" left="5"/>
  </padding>
</StackPane>