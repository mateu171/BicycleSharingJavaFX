<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.view.mechanic.MechanicIssuesController">

  <children>
    <VBox spacing="14" styleClass="users-page">
      <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
      </padding>

      <Label fx:id="titleLabel" styleClass="settings-title"/>

      <HBox spacing="14" styleClass="users-toolbar" alignment="BOTTOM_LEFT">
        <children>
          <VBox spacing="4" HBox.hgrow="ALWAYS">
            <children>
              <Label fx:id="searchLabel" styleClass="form-label"/>
              <TextField fx:id="searchField"
                styleClass="modal-text-field"
                prefWidth="260"/>
            </children>
          </VBox>

          <VBox spacing="4">
            <children>
              <Label fx:id="statusFilterLabel" styleClass="form-label"/>
              <ComboBox fx:id="statusFilterCombo"
                prefWidth="190"
                styleClass="settings-combo"/>
            </children>
          </VBox>

          <VBox spacing="4">
            <children>
              <Label fx:id="technicalFilterLabel" styleClass="form-label"/>
              <ComboBox fx:id="technicalFilterCombo"
                prefWidth="190"
                styleClass="settings-combo"/>
            </children>
          </VBox>

          <VBox spacing="4">
            <children>
              <Label fx:id="sortLabel" styleClass="form-label"/>
              <ComboBox fx:id="sortCombo"
                prefWidth="190"
                styleClass="settings-combo"/>
            </children>
          </VBox>
        </children>
      </HBox>

      <HBox spacing="10" alignment="CENTER_LEFT" styleClass="users-stats">
        <children>
          <Label fx:id="countLabel" styleClass="users-count-label"/>
          <HBox HBox.hgrow="ALWAYS"/>
          <Button fx:id="takeInWorkButton"
            onAction="#onTakeInWork"
            styleClass="button-edit"/>
          <Button fx:id="resolveButton"
            onAction="#onResolve"
            styleClass="button-primary"/>
          <Button fx:id="detailsButton"
            onAction="#onShowDetails"
            styleClass="button-secondary-outline"/>
        </children>
      </HBox>

      <TableView fx:id="issuesTable" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="bikeColumn"/>
          <TableColumn fx:id="technicalColumn"/>
          <TableColumn fx:id="dateColumn"/>
          <TableColumn fx:id="statusColumn"/>
        </columns>
      </TableView>
    </VBox>
  </children>
</StackPane>