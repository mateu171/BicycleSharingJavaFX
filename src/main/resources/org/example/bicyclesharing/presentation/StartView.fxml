<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.AnchorPane?>

<StackPane prefHeight="500" prefWidth="400"
  styleClass="stack-pane-root"
  stylesheets="@../css/style.css"
  xmlns="http://javafx.com/javafx/25"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.StartController">

  <!-- Контент поверх StackPane -->
  <StackPane fx:id="contentPane" />

  <!-- TitleBar поверх, тільки кнопки -->
  <HBox fx:id="titleBar" spacing="5"
    alignment="TOP_RIGHT"
    style="-fx-padding: 10;"
    pickOnBounds="false">
    <Button fx:id="minimizeButton" onAction="#minimizeWindow" styleClass="title-button" text="—" />
    <Button fx:id="closeButton" onAction="#closeWindow" styleClass="title-button" text="✕" />
  </HBox>

</StackPane>
