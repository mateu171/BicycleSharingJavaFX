<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.view.mechanic.MechanicServiceController">

  <children>
    <VBox spacing="14" styleClass="users-page">
      <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
      </padding>

      <Label fx:id="titleLabel" styleClass="settings-title"/>

      <HBox spacing="10" styleClass="users-toolbar">
        <children>
          <VBox>
            <children>
              <Label fx:id="searchLabel" styleClass="form-label" text="Пошук"/>
               <TextField fx:id="searchField"
                 styleClass="modal-text-field"/>
            </children>
          </VBox>
          <VBox>
            <children>
              <Label fx:id="statusLabel" styleClass="form-label" text="Фільтер"/>
              <ComboBox fx:id="stateFilterCombo"
                styleClass="settings-combo"/>
            </children>
          </VBox>
          <VBox>
            <children>
              <Label fx:id="sortLabel" styleClass="form-label" text="Сортування"/>
              <ComboBox fx:id="sortCombo"
                styleClass="settings-combo"/>
            </children>
          </VBox>
        </children>
      </HBox>

      <HBox spacing="10" alignment="CENTER_LEFT" styleClass="users-stats">
        <children>
          <Label fx:id="countLabel" styleClass="users-count-label"/>
          <HBox HBox.hgrow="ALWAYS"/>
          <Button fx:id="inspectButton"
            onAction="#onNeedsInspection"
            styleClass="button-edit"/>
          <Button fx:id="maintenanceButton"
            onAction="#onMaintenance"
            styleClass="button-secondary-outline"/>
          <Button fx:id="availableButton"
            onAction="#onAvailable"
            styleClass="button-primary"/>
          <Button fx:id="unavailableButton"
            onAction="#onUnavailable"
            styleClass="button-danger"/>
        </children>
      </HBox>

      <TableView fx:id="bicyclesTable" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="modelColumn"/>
          <TableColumn fx:id="priceColumn"/>
          <TableColumn fx:id="stateColumn"/>
        </columns>
      </TableView>
    </VBox>
  </children>
</StackPane>