<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.view.user.modalController.RideFeedbackDialogController"
  styleClass="modal-root">

  <children>
    <VBox maxWidth="420" prefWidth="420" spacing="0" styleClass="modal-card">
      <children>
        <HBox alignment="CENTER_LEFT" styleClass="modal-header">
          <children>
            <Label fx:id="titleLabel" styleClass="modal-title"/>
          </children>
        </HBox>

        <VBox spacing="16" styleClass="modal-body">
          <children>
            <Label fx:id="questionLabel" styleClass="form-label"/>
          </children>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="modal-footer">
          <children>
            <Button fx:id="yesButton"
              onAction="#onYes"
              styleClass="button-primary"/>
            <Button fx:id="noButton"
              onAction="#onNo"
              styleClass="button-secondary-outline"/>
          </children>
        </HBox>
      </children>
    </VBox>
  </children>
</StackPane>