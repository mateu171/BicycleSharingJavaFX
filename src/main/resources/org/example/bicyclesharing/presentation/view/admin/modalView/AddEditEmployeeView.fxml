<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.view.admin.modalController.AddEditEmployeeController"
  styleClass="modal-root">

  <VBox prefWidth="460" maxWidth="460" styleClass="modal-card">

    <HBox alignment="CENTER_LEFT" styleClass="modal-header">
      <Label fx:id="titleLabel" styleClass="modal-title"/>
      <Pane HBox.hgrow="ALWAYS"/>
    </HBox>

    <VBox spacing="12" styleClass="modal-body">
      <VBox spacing="4">
        <Label fx:id="nameLabel" styleClass="form-label"/>
        <TextField fx:id="nameField" styleClass="modal-text-field"/>
        <Label fx:id="nameErrorLabel" styleClass="label-error" wrapText="true"/>
      </VBox>

      <VBox spacing="4">
        <Label fx:id="phoneLabel" styleClass="form-label"/>
        <TextField fx:id="phoneField" styleClass="modal-text-field"/>
        <Label fx:id="phoneErrorLabel" styleClass="label-error" wrapText="true"/>
      </VBox>

      <VBox spacing="4">
        <Label fx:id="stationLabel" styleClass="form-label"/>
        <ComboBox fx:id="stationComboBox" styleClass="modal-combo"/>
        <Label fx:id="stationErrorLabel" styleClass="label-error" wrapText="true"/>
      </VBox>

      <VBox spacing="4">
        <Label fx:id="salaryLabel" styleClass="form-label"/>
        <TextField fx:id="salaryField" styleClass="modal-text-field"/>
        <Label fx:id="salaryErrorLabel" styleClass="label-error" wrapText="true"/>
      </VBox>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="modal-footer">
      <Button fx:id="cancelButton"
        onAction="#onClose"
        styleClass="button-secondary-outline"/>
      <Button fx:id="saveButton"
        onAction="#onSave"
        styleClass="button-primary"/>
    </HBox>
  </VBox>

  <padding>
    <Insets top="20" right="20" bottom="20" left="20"/>
  </padding>
</StackPane>