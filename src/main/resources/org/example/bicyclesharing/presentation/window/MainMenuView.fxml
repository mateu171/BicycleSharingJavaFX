<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>
<StackPane prefHeight="600" prefWidth="900"
  styleClass="stack-pane-root"
  stylesheets="@../../css/style.css"
  style="-fx-border-radius: 0; -fx-background-radius: 0;"
  xmlns="http://javafx.com/javafx/25"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.window.MainMenuController">

  <AnchorPane>

    <HBox fx:id="titleBar"
    prefHeight="40"
    styleClass="title-bar"
    AnchorPane.topAnchor="0"
    AnchorPane.leftAnchor="0"
    AnchorPane.rightAnchor="0"
    onMousePressed="#handleMousePressed"
    onMouseDragged="#handleMouseDragged">

    <Pane HBox.hgrow="ALWAYS"/>

    <Button onAction="#minimizeWindow" styleClass="title-button" text="—"/>
    <Button onAction="#fullSize" styleClass="title-button" text="□"/>
    <Button onAction="#closeWindow" styleClass="title-button" text="✕"/>

  </HBox>

    <HBox AnchorPane.topAnchor="40"
      AnchorPane.bottomAnchor="0"
      AnchorPane.leftAnchor="0"
      AnchorPane.rightAnchor="0">

      <VBox fx:id="sidebar" styleClass="sidebar">


        <HBox fx:id="adminUsersContainer" styleClass="menu-container" spacing="10" alignment="CENTER_LEFT" visible="false" managed="false">
          <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
            <image>
              <Image url="@../../art/icon/anotheruser.png" />
            </image>
          </ImageView>
          <Button fx:id="btnUsers" styleClass="menu-button" onAction="#onShowUsers"/>
        </HBox>

        <HBox fx:id="adminBicyclesContainer" styleClass="menu-container" spacing="10" alignment="CENTER_LEFT" visible="false" managed="false">
          <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
            <image>
              <Image url="@../../art/icon/bicycle.png" />
            </image>
          </ImageView>
          <Button fx:id="btnBicycles" styleClass="menu-button" onAction="#onShowBicycles"/>
        </HBox>

        <HBox fx:id="adminStationContainer" styleClass="menu-container" spacing="10" alignment="CENTER_LEFT" visible="false" managed="false">
          <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
            <image>
              <Image url="@../../art/icon/bicycleStation.png" />
            </image>
          </ImageView>
          <Button fx:id="btnStations" styleClass="menu-button" onAction="#onShowStations"/>
        </HBox>

        <HBox fx:id="mechanicIssuesContainer" styleClass="menu-container" spacing="10"
          alignment="CENTER_LEFT" visible="false" managed="false">
          <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
            <image>
              <Image url="@../../art/icon/issue.png" />
            </image>
          </ImageView>
          <Button fx:id="btnMechanicIssues" styleClass="menu-button" onAction="#onShowMechanicIssues"/>
        </HBox>

        <HBox fx:id="mechanicServiceContainer" styleClass="menu-container" spacing="10"
          alignment="CENTER_LEFT" visible="false" managed="false">
          <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
            <image>
              <Image url="@../../art/icon/maintenance.png" />
            </image>
          </ImageView>
          <Button fx:id="btnMechanicService" styleClass="menu-button" onAction="#onShowMechanicService"/>
        </HBox>

        <HBox fx:id="mechanicHistoryContainer" styleClass="menu-container" spacing="10"
          alignment="CENTER_LEFT" visible="false" managed="false">
          <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
            <image>
              <Image url="@../../art/icon/history.png" />
            </image>
          </ImageView>
          <Button fx:id="btnMechanicHistory" styleClass="menu-button" onAction="#onShowMechanicHistory"/>
        </HBox>

        <HBox fx:id="mechanicRecordContainer" styleClass="menu-container" spacing="10"
          alignment="CENTER_LEFT" visible="false" managed="false">
          <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
            <image>
              <Image url="@../../art/icon/addRecord.png" />
            </image>
          </ImageView>
          <Button fx:id="btnMechanicRecord" styleClass="menu-button" onAction="#onShowMechanicAddRecord"/>
        </HBox>

        <HBox fx:id="managerCustomersContainer" styleClass="menu-container" spacing="10"
          alignment="CENTER_LEFT" visible="false" managed="false">
          <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
            <image>
              <Image url="@../../art/icon/customer.png" />
            </image>
          </ImageView>
          <Button fx:id="btnManagerCustomers" styleClass="menu-button" onAction="#onShowCustomerManager"/>
        </HBox>

        <HBox fx:id="managerReservationContainer" styleClass="menu-container" spacing="10"
          alignment="CENTER_LEFT" visible="false" managed="false">
          <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
            <image>
              <Image url="@../../art/icon/booking.png" />
            </image>
          </ImageView>
          <Button fx:id="btnManagerReservation" styleClass="menu-button" onAction="#onShowReservation"/>
        </HBox>

        <HBox fx:id="managerAcitveRentalsContainer" styleClass="menu-container" spacing="10"
          alignment="CENTER_LEFT" visible="false" managed="false">
          <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
            <image>
              <Image url="@../../art/icon/rent.png" />
            </image>
          </ImageView>
          <Button fx:id="btnManagerActiveRentals" styleClass="menu-button" onAction="#onShowActiveRentals"/>
        </HBox>

        <HBox fx:id="settingsContainer" styleClass="menu-container" spacing="10" alignment="CENTER_LEFT">
          <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
            <image>
              <Image url="@../../art/icon/settings.png" />
            </image>
          </ImageView>
          <Button fx:id="btnSettings" styleClass="menu-button" onAction="#onShowSettings"/>
        </HBox>

      </VBox>

      <StackPane fx:id="contentPane"
        HBox.hgrow="ALWAYS">

        <HBox.margin>
          <Insets top="0" right="10" bottom="0" left="10"/>
        </HBox.margin>

      </StackPane>

    </HBox>

  </AnchorPane>

</StackPane>