<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>
<StackPane prefHeight="600" prefWidth="900"
  styleClass="stack-pane-root"
  stylesheets="@../../css/style.css"
  style="-fx-border-radius: 0; -fx-background-radius: 0;"
  xmlns="http://javafx.com/javafx/25"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.window.MainMenuController">

  <AnchorPane>

    <HBox fx:id="titleBar"
    prefHeight="40"
    styleClass="title-bar"
    AnchorPane.topAnchor="0"
    AnchorPane.leftAnchor="0"
    AnchorPane.rightAnchor="0"
    onMousePressed="#handleMousePressed"
    onMouseDragged="#handleMouseDragged">

    <Pane HBox.hgrow="ALWAYS"/>

    <Button onAction="#minimizeWindow" styleClass="title-button" text="—"/>
    <Button onAction="#fullSize" styleClass="title-button" text="□"/>
    <Button onAction="#closeWindow" styleClass="title-button" text="✕"/>

  </HBox>

    <HBox AnchorPane.topAnchor="40"
      AnchorPane.bottomAnchor="0"
      AnchorPane.leftAnchor="0"
      AnchorPane.rightAnchor="0">

      <VBox fx:id="sidebar" styleClass="sidebar">
        <VBox fx:id="menuContent" spacing="6"/>
      </VBox>

      <StackPane fx:id="contentPane"
        HBox.hgrow="ALWAYS">

        <HBox.margin>
          <Insets top="0" right="10" bottom="0" left="10"/>
        </HBox.margin>

      </StackPane>

    </HBox>

  </AnchorPane>

</StackPane>