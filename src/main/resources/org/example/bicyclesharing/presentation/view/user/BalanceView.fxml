<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.view.user.BalanceController"
  styleClass="stack-pane-root">

  <VBox spacing="25"
    alignment="CENTER"
    prefWidth="500">

    <Label fx:id="title" styleClass="label-title"/>

    <StackPane prefWidth="200"
      prefHeight="200"
      maxWidth="200"
      maxHeight="200"
      styleClass="balance-circle">

      <VBox alignment="CENTER" spacing="5">
        <Label fx:id="yourBalance" style="-fx-text-fill: #364153;"/>

        <Label fx:id="balanceLabel"
          text="0.00₴"
          style="-fx-font-size: 26px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #364153;"/>
      </VBox>
    </StackPane>

    <Label fx:id="selectTopUp" style="-fx-text-fill: #364153;"/>

    <HBox fx:id="topUpButtons" spacing="15" alignment="CENTER">

      <Button fx:id="btn100" text="100₴"
        styleClass="top-up-button"/>

      <Button fx:id="btn200" text="200₴"
        styleClass="top-up-button"/>

      <Button fx:id="btn500" text="500₴"
        styleClass="top-up-button"/>
    </HBox>

    <Label fx:id="topUp" style="-fx-text-fill: #364153;"/>

    <TextField fx:id="topUpField"
      text="200"
      maxWidth="250"
      alignment="CENTER"
      styleClass="text-field-style"/>

    <Button fx:id="replenishButton"
      prefWidth="250"
      styleClass="button-primary"/>

  </VBox>

</StackPane>