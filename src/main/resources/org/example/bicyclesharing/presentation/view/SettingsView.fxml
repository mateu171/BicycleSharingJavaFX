<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<StackPane
  xmlns="http://javafx.com/javafx"
  xmlns:fx="http://javafx.com/fxml"
  fx:controller="org.example.bicyclesharing.controller.view.SettingsController"
  prefHeight="500.0"
  prefWidth="700.0"
  styleClass="stack-pane-root">

  <fx:define>
    <ToggleGroup fx:id="themeToggleGroup"/>
  </fx:define>

  <VBox spacing="25">

    <Label
      fx:id="titleLabel"
      styleClass="label-title"/>

    <VBox
      spacing="10"
      styleClass="settings-card">

      <Label
        fx:id="languageLabel"
        styleClass="settings-section-title"/>

      <ComboBox
        fx:id="languageComboBox"
        prefWidth="250"
        styleClass="settings-combo"/>
    </VBox>

    <VBox
      spacing="10"
      styleClass="settings-card">

      <Label
        fx:id="themeLabel"
        styleClass="settings-section-title"/>

      <HBox
        spacing="20">

        <RadioButton
          fx:id="lightThemeRadio"
          toggleGroup="$themeToggleGroup"
          styleClass="settings-radio"/>

        <RadioButton
          fx:id="darkThemeRadio"
          toggleGroup="$themeToggleGroup"
          styleClass="settings-radio"/>

      </HBox>
    </VBox>

    <Button
      fx:id="saveButton"
      prefWidth="200"
      styleClass="settings-save-button"
      onAction="#saveChange"/>

  </VBox>

  <Button
    fx:id="logoutButton"
    onAction="#logout"
    styleClass="settings-logout-button"
    StackPane.alignment="BOTTOM_RIGHT">

    <graphic>
      <ImageView fitWidth="20" fitHeight="20" pickOnBounds="true" preserveRatio="true">
        <image>
          <Image url="@../../art/icon/exit.png"/>
        </image>
      </ImageView>
    </graphic>
    <StackPane.margin>
      <Insets top="10" right="10" bottom="10" left="10"/>
    </StackPane.margin>
  </Button>

</StackPane>