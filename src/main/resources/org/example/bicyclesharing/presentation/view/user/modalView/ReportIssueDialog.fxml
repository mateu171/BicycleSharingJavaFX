<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.view.user.modalController.ReportIssueDialogController"
  styleClass="modal-root">

  <children>
    <VBox maxWidth="460" prefWidth="460" spacing="0" styleClass="modal-card">
      <children>
        <HBox alignment="CENTER_LEFT" styleClass="modal-header">
          <children>
            <Label fx:id="titleLabel" styleClass="modal-title" text="Повідомлення про проблему"/>
            <HBox HBox.hgrow="ALWAYS"/>
          </children>
        </HBox>

        <VBox spacing="14" styleClass="modal-body">
          <children>
            <Label fx:id="headerLabel"
              styleClass="form-label"
              text="Що саме було не так?"/>

            <Label fx:id="problemTypeLabel"
              styleClass="form-label"
              text="Тип проблеми"/>

            <ComboBox fx:id="problemTypeComboBox"
              prefWidth="420"
              styleClass="modal-combo"/>

            <Label fx:id="commentLabel"
              styleClass="form-label"
              text="Коментар"/>

            <TextArea fx:id="commentTextArea"
              prefRowCount="5"
              wrapText="true"
              styleClass="modal-text-field"/>

            <Label fx:id="errorLabel"
              managed="false"
              visible="false"
              styleClass="label-error"/>
          </children>
          <padding>
            <Insets top="0" right="0" bottom="0" left="0"/>
          </padding>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="modal-footer">
          <children>
            <Button fx:id="cancelButton"
              onAction="#onClose"
              styleClass="button-secondary-outline"
              text="Скасувати"/>
            <Button fx:id="submitButton"
              onAction="#onSubmit"
              styleClass="button-primary"
              text="Надіслати"/>
          </children>
        </HBox>
      </children>
    </VBox>
  </children>
</StackPane>