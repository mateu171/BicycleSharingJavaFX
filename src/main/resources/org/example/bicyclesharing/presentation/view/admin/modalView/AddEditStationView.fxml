<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.view.admin.modalController.AddEditStationController"
  styleClass="modal-root">

  <VBox prefWidth="460" maxWidth="460" styleClass="modal-card">

    <HBox alignment="CENTER_LEFT" styleClass="modal-header">
      <Label fx:id="titleLabel" styleClass="modal-title"/>
      <Pane HBox.hgrow="ALWAYS"/>
    </HBox>

    <VBox spacing="12" styleClass="modal-body">
      <VBox spacing="4">
        <Label fx:id="nameLabel" styleClass="form-label"/>
        <TextField fx:id="nameField" styleClass="modal-text-field"/>
        <Label fx:id="nameErrorLabel" styleClass="label-error" wrapText="true"/>
      </VBox>

      <VBox spacing="4">
        <Label text="Локація" styleClass="form-label"/>
        <Button fx:id="pickOnMapButton"
          onAction="#onPickOnMap"
          styleClass="button-secondary-outline"/>
        <Label fx:id="locationInfoLabel"
          styleClass="form-hint"
          wrapText="true"/>
        <Label fx:id="latitudeErrorLabel"
          styleClass="label-error"
          wrapText="true"/>
      </VBox>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="modal-footer">
      <Button fx:id="cancelButton"
        onAction="#onClose"
        styleClass="button-secondary-outline"/>
      <Button fx:id="saveButton"
        onAction="#onSave"
        styleClass="button-primary"/>
    </HBox>
  </VBox>

  <padding>
    <Insets top="20" right="20" bottom="20" left="20"/>
  </padding>
</StackPane>