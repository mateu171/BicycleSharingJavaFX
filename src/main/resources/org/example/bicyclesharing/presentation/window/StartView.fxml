<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<StackPane prefHeight="500" prefWidth="400"
  styleClass="stack-pane-root"
  stylesheets="@../../css/style.css"
  xmlns="http://javafx.com/javafx/25"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.window.StartController">

  <StackPane fx:id="contentPane" />

  <HBox spacing="5"
    alignment="TOP_RIGHT"
    style="-fx-padding: 10;"
    pickOnBounds="false">
    <Button onAction="#minimizeWindow" styleClass="title-button" text="—" />
    <Button onAction="#closeWindow" styleClass="title-button" text="✕" />
  </HBox>

  <HBox alignment="BOTTOM_RIGHT"
    style="-fx-padding: 15;"
    pickOnBounds="false">

    <Button
      onAction="#switchLanguage"
      styleClass="language-button">

      <graphic>
        <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
          <image>
            <Image url="@../../art/icon/lang.png"/>
          </image>
        </ImageView>
      </graphic>

    </Button>

  </HBox>

</StackPane>
