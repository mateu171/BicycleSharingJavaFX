<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.view.manager.modalController.AddEditCustomerController"
  styleClass="modal-root">

  <VBox prefWidth="460"
    maxWidth="460"
    styleClass="modal-card">

    <HBox alignment="CENTER_LEFT"
      styleClass="modal-header">
      <Label fx:id="titleLabel"
        styleClass="modal-title"/>

      <Pane HBox.hgrow="ALWAYS"/>
    </HBox>

    <VBox spacing="12"
      styleClass="modal-body">

      <VBox spacing="4">
        <Label fx:id="fullNameLabel"
          styleClass="form-label"/>

        <TextField fx:id="fullNameField"
          styleClass="modal-text-field"/>

        <Label fx:id="fullNameErrorLabel"
          styleClass="label-error"
          wrapText="true"/>
      </VBox>

      <VBox spacing="4">
        <Label fx:id="phoneNumberLabel"
          styleClass="form-label"/>

        <TextField fx:id="phoneNumberField"
          styleClass="modal-text-field"/>

        <Label fx:id="phoneNumberErrorLabel"
          styleClass="label-error"
          wrapText="true"/>
      </VBox>

      <VBox spacing="4">
        <Label fx:id="documentNumberLabel"
          styleClass="form-label"/>

        <TextField fx:id="documentNumberField"
          styleClass="modal-text-field"/>

        <Label fx:id="documnetNumberErrorLabel"
          styleClass="label-error"
          wrapText="true"/>
      </VBox>

    </VBox>

    <HBox spacing="10"
      alignment="CENTER_RIGHT"
      styleClass="modal-footer">

      <Button fx:id="cancelButton"
        onAction="#onClose"
        styleClass="button-secondary-outline"/>

      <Button fx:id="saveButton"
        onAction="#onSave"
        styleClass="button-primary"/>
    </HBox>
  </VBox>

  <padding>
    <Insets top="20" right="20" bottom="20" left="20"/>
  </padding>
</StackPane>