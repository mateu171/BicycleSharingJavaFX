<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="org.example.bicyclesharing.controller.view.mechanic.MechanicIssuesController">

  <children>
    <VBox spacing="14" styleClass="users-page">
      <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
      </padding>

      <Label fx:id="titleLabel" styleClass="settings-title"/>

      <HBox spacing="10" styleClass="users-toolbar">
        <children>
          <TextField fx:id="searchField"
            promptText="Пошук..."
            styleClass="modal-text-field"/>
          <ComboBox fx:id="statusFilterCombo"
            prefWidth="180"
            styleClass="settings-combo"/>
          <ComboBox fx:id="technicalFilterCombo"
            prefWidth="180"
            styleClass="settings-combo"/>
          <ComboBox fx:id="sortCombo"
            prefWidth="180"
            styleClass="settings-combo"/>
        </children>
      </HBox>

      <HBox spacing="10" alignment="CENTER_LEFT" styleClass="users-stats">
        <children>
          <Label fx:id="countLabel" styleClass="users-count-label"/>
          <HBox HBox.hgrow="ALWAYS"/>
          <Button fx:id="takeInWorkButton"
            onAction="#onTakeInWork"
            styleClass="button-edit"/>
          <Button fx:id="resolveButton"
            onAction="#onResolve"
            styleClass="button-primary"/>
        </children>
      </HBox>

      <TableView fx:id="issuesTable" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="bikeColumn" prefWidth="160" text="Велосипед"/>
          <TableColumn fx:id="problemColumn" prefWidth="180" text="Проблема"/>
          <TableColumn fx:id="commentColumn" prefWidth="260" text="Коментар"/>
          <TableColumn fx:id="technicalColumn" prefWidth="110" text="Технічна"/>
          <TableColumn fx:id="dateColumn" prefWidth="150" text="Дата"/>
          <TableColumn fx:id="statusColumn" prefWidth="130" text="Статус"/>
        </columns>
      </TableView>
    </VBox>
  </children>
</StackPane>