<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
  xmlns:fx="http://javafx.com/fxml"
  fx:controller="org.example.bicyclesharing.controller.view.user.TransactionController"
  styleClass="stack-pane-root">

  <VBox spacing="15">

    <Label fx:id="title" styleClass="label-title"/>

    <ListView fx:id="transactionListView"
      VBox.vgrow="ALWAYS"
      styleClass="transaction-list"/>

  </VBox>

</StackPane>
